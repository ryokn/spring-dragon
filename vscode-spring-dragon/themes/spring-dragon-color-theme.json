  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#737C73"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#C5C9C5"
      }
    },
    {
      "name": "Constant name (readonly variable)",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "constant.other"
      ],
      "settings": {
        "foreground": "#C5C9C5"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#E82424"
      }
    },
    {
      "name": "Storage - Type",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#8992A7"
      }
    },
    {
      "name": "Storage - Modifier",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8992A7"
      }
    },
    {
      "name": "Function declaration keyword (def/fn/func)",
      "scope": [
        "storage.type.function",
        "storage.type.class",
        "keyword.declaration.function",
        "keyword.declaration.class"
      ],
      "settings": {
        "foreground": "#8992A7"
      }
    },
    {
      "name": "Control Keyword",
      "scope": [
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#8992A7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword.control",
        "keyword.other.template",
        "keyword.other.substitution",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#8992A7"
      }
    },
    {
      "name": "Try/Catch Keyword",
      "scope": [
        "keyword.control.trycatch"
      ],
      "settings": {
        "foreground": "#C4746E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Import",
      "scope": [
        "keyword.control.import",
        "keyword.import",
        "meta.import"
      ],
      "settings": {
        "foreground": "#B6927B"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#C4B28A"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.section.embedded",
        "meta.brace",
        "keyword.operator.type.annotation",
        "keyword.operator.namespace"
      ],
      "settings": {
        "foreground": "#9E9B93"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string",
        "constant.other.symbol",
        "constant.other.key",
        "entity.other.inherited-class",
        "markup.inline.raw.string"
      ],
      "settings": {
        "foreground": "#8A9A7B"
      }
    },
    {
      "name": "String escape / Regexp",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#949FB5"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#A292A3"
      }
    },
    {
      "name": "Boolean / Language constant",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#B6927B"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "constant.character",
        "constant.escape"
      ],
      "settings": {
        "foreground": "#B6927B"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#8BA4B0"
      }
    },
    {
      "name": "Macro",
      "scope": [
        "entity.name.function.macro"
      ],
      "settings": {
        "foreground": "#C4746E"
      }
    },
    {
      "name": "Type / Class",
      "scope": [
        "entity.name",
        "support.type",
        "support.class",
        "support.type.sys-types"
      ],
      "settings": {
        "foreground": "#8EA4A2"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.type.module",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#C4B28A"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#C4B28A"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8992A7"
      }
    },
    {
      "name": "CSS Class",
      "scope": [
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#C4B28A"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#C4B28A"
      }
    },
    {
      "name": "Enum Member",
      "scope": [
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#B6927B"
      }
    },
    {
      "name": "Language variable (self/this)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#C4746E"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name"
      ],
      "settings": {
        "foreground": "#8EA4A2"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#76946A"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#C34043"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#DCA561"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markdown.heading",
        "entity.name.section.markdown",
        "markup.heading.markdown"
      ],
      "settings": {
        "foreground": "#8BA4B0"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#C4746E"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold",
        "markup.bold string"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#B6927B"
      }
    },
    {
      "name": "Markup underline",
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#949FB5"
      }
    },
    {
      "name": "Markdown separator",
      "scope": [
        "meta.separator"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#9E9B93"
      }
    },
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#A292A3"
      }
    },
    {
      "name": "JSON Key - Level 1",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#C4B28A"
      }
    },
    {
      "name": "JSON Key - Level 2",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#B6927B"
      }
    }
  ]
}